rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is an admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Packs collection ───
    match /packs/{packId} {
      // Anyone can read approved packs
      allow read: if resource.data.status == 'approved' || 
                     (request.auth != null && resource.data.authorId == request.auth.uid) ||
                     isAdmin();
      
      // Authenticated users can create packs (must be pending)
      allow create: if request.auth != null && 
                       request.resource.data.status == 'pending' &&
                       request.resource.data.authorId == request.auth.uid;
      
      // Author can update their own pack (but NOT change status)
      allow update: if request.auth != null && (
        (resource.data.authorId == request.auth.uid && 
         request.resource.data.status == resource.data.status) ||
        isAdmin()
      );
      
      // Anyone can increment download count
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads']);
      
      // Only admins can delete
      allow delete: if isAdmin();

      // ─── Ratings subcollection ───
      match /ratings/{ratingId} {
        allow read: if true;
        
        // Authenticated users: one rating per user (doc ID = userId)
        allow create, update: if request.auth != null && 
                                  ratingId == request.auth.uid &&
                                  request.resource.data.stars >= 1 &&
                                  request.resource.data.stars <= 5;
        
        // Only the author can delete their own rating
        allow delete: if request.auth != null && ratingId == request.auth.uid;
      }
    }

    // ─── Users collection ───
    match /users/{userId} {
      // Public profiles — anyone can read
      allow read: if true;
      
      // Only the user themselves or Cloud Functions can create/update
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Users can't self-delete from here
    }

    // ─── Admins collection ───
    match /admins/{adminId} {
      allow read: if request.auth != null;
      allow write: if false; // Only set via Firebase Console
    }
  }
}
