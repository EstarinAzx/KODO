# Firebase Configuration for KODO Pack Registry
# Copy this file to .env and fill in your values
# Get these from Firebase Console > Project Settings > General > Your apps

KODO_FIREBASE_API_KEY=your-api-key
KODO_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
KODO_FIREBASE_PROJECT_ID=your-project-id
KODO_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
KODO_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
KODO_FIREBASE_APP_ID=your-app-id
